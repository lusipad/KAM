# AI工作助手 - 环境变量配置

# OpenAI API配置 (必需)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# 应用安全配置
APP_SECRET_KEY=your-secret-key-here-change-in-production
APP_CORS_ORIGINS=http://localhost:8000,http://localhost,http://localhost:5173

# 数据库配置 (使用默认值通常不需要修改)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_assistant
# REDIS_URL=redis://redis:6379/0

# Azure DevOps配置 (可选)
# AZURE_DEVOPS_DEFAULT_ORG=your-organization
# AZURE_DEVOPS_DEFAULT_PROJECT=your-project
