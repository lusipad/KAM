# KAM Lite - 环境变量示例

APP_CORS_ORIGINS=http://localhost:8000,http://localhost,http://localhost:5173

# 本地默认使用 SQLite，可按需切到 PostgreSQL
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/kam_lite

AGENT_WORKROOT=./storage/agent-runs
CODEX_CLI_PATH=codex
CLAUDE_CODE_CLI_PATH=claude

# v2 路由与默认 Codex 模型
ROUTER_MODEL=gpt-5.4
ROUTER_REASONING_EFFORT=xhigh
CODEX_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=xhigh

# 可选：启用 Anthropic 对话 / 摘要能力（未配置时自动回退到规则逻辑）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5
ANTHROPIC_SMALL_MODEL=claude-sonnet-4-6

# OpenAI 仅保留给嵌入与 Codex 相关能力
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
