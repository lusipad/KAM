# KAM Harness - 环境变量示例
#
# 本地首次启动通常不需要改动。
# 如需自定义模型、CLI 路径或外部系统 token，再复制为根目录 .env 后修改。

APP_ENV=development
APP_DEBUG=false
APP_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=sqlite+aiosqlite:///./storage/kam-harness.db
STORAGE_PATH=./storage
RUN_ROOT=./storage/runs

CLAUDE_CODE_PATH=claude
CODEX_PATH=codex

ANTHROPIC_API_KEY=
CHAT_MODEL=claude-sonnet-4-20250514
DIGEST_MODEL=claude-sonnet-4-20250514

GITHUB_TOKEN=
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_ORG=

GIT_USER_NAME=KAM Bot
GIT_USER_EMAIL=kam@example.com
